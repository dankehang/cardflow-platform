{
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfig": {
      "env": {
        "NODE_ENV": "production"
      },
      "phases": {
        "setup": {
          "pkgs": ["nodejs", "npm"]
        },
        "install": {
          "cmd": "cd backend && rm -rf node_modules package-lock.json && npm install --production"
        },
        "build": {
          "cmd": "cd backend && echo 'Build completed'"
        }
      },
      "start": {
        "cmd": "cd backend && npm start"
      }
    }
  },
  "deploy": {
    "startCommand": "cd backend && npm start"
  }
}