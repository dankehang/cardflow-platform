{
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfig": {
      "providers": {
        "node": {
          "version": "18.x"
        }
      },
      "phases": {
        "setup": {
          "pkgs": ["nodejs", "npm", "chromium", "nss", "freetype", "harfbuzz", "ca-certificates", "ttf-freefont"]
        },
        "install": {
          "cmd": "npm install --no-fund --no-audit"
        },
        "build": {
          "cmd": "echo 'Build completed'"
        }
      },
      "start": {
        "cmd": "npm start"
      }
    }
  },
  "deploy": {
    "startCommand": "npm start"
  }
}