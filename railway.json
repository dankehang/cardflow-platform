{
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfig": {
      "phases": {
        "setup": {
          "pkgs": ["nodejs", "npm", "bash"]
        },
        "install": {
          "cmd": "cd backend && chmod +x start.sh && npm install"
        },
        "build": {
          "cmd": "cd backend && echo 'Build completed'"
        }
      },
      "start": {
        "cmd": "cd backend && ./start.sh"
      }
    }
  },
  "deploy": {
    "startCommand": "cd backend && ./start.sh"
  }
}