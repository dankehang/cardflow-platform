{
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfig": {
      "phases": {
        "setup": {
          "pkgs": ["nodejs", "npm"]
        },
        "install": {
          "cmd": "npm install"
        },
        "build": {
          "cmd": "echo 'Build completed'"
        }
      },
      "start": {
        "cmd": "npm start"
      }
    }
  },
  "deploy": {
    "startCommand": "npm start"
  }
}